# Server
PROXMOX_MCP_ENVIRONMENT=homelab
PROXMOX_MCP_SERVER_HOST=0.0.0.0
PROXMOX_MCP_SERVER_PORT=8443
PROXMOX_MCP_LOG_LEVEL=info

# Runtime
PROXMOX_MCP_DURABLE_STATE_ENABLED=true
PROXMOX_MCP_EXTERNAL_AUTH_ENABLED=true

# Auth (homelab service token)
PROXMOX_MCP_AUTH_MODE=service_token
PROXMOX_MCP_SERVICE_TOKEN=replace-with-long-random-token
PROXMOX_MCP_DEFAULT_ACTOR__USER_ID=operator
PROXMOX_MCP_DEFAULT_ACTOR__AGENT_ID=homelab-agent

# TLS
PROXMOX_MCP_TLS__CERT_FILE=./certs/local/tls.crt
PROXMOX_MCP_TLS__KEY_FILE=./certs/local/tls.key
PROXMOX_MCP_TLS__GENERATE_SELF_SIGNED=false

# Database
PROXMOX_MCP_DATABASE_URL=postgresql+asyncpg://proxmox_mcp:change-me@localhost:5432/proxmox_mcp?ssl=require
PROXMOX_MCP_POSTGRES_PASSWORD=change-me

# Redis
PROXMOX_MCP_REDIS_URL=rediss://localhost:6379/0

# Secrets
PROXMOX_MCP_CREDENTIAL_PROVIDER=development
PROXMOX_MCP_SECRETS_FILE=./secrets.local.json

# Proxmox cluster
PROXMOX_MCP_CLUSTER__CLUSTER_ID=homelab
PROXMOX_MCP_CLUSTER__NAME=Homelab Proxmox
PROXMOX_MCP_CLUSTER__API_ENDPOINT=https://pve.example.test:8006
PROXMOX_MCP_CLUSTER__TLS_VERIFY=true
PROXMOX_MCP_CLUSTER__ENVIRONMENT=homelab
PROXMOX_MCP_CLUSTER__CREDENTIAL_REF__PROVIDER=development
PROXMOX_MCP_CLUSTER__CREDENTIAL_REF__PATH=clusters/homelab/proxmox-api
PROXMOX_MCP_CLUSTER__CREDENTIAL_REF__PURPOSE=proxmox_api

# Observability (optional)
# PROXMOX_MCP_OBSERVABILITY__PROMETHEUS_URL=https://prometheus.example.test
# PROXMOX_MCP_OBSERVABILITY__ALERTMANAGER_URL=https://alertmanager.example.test

# Lab gates (optional, never commit real credentials)
# PROXMOX_MCP_LAB_ENABLED=true
# PROXMOX_MCP_LAB_API_ENDPOINT=https://pve.example.test:8006
